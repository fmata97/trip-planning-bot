{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "trip-planning-bot",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-30",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"ai": {
		"binding": "AI"
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "TRIP_AGENT",
				"class_name": "TripAgent"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["TripAgent"]
		}
	]
}
